{
  "title": "Inference Engineering",
  "uid": "inference-engineering-v1",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(inference_requests_total[1m])) by (endpoint)",
          "legendFormat": "{{endpoint}}",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 2,
      "title": "Request Latency — P50 / P95 / P99 (/search)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(inference_request_duration_seconds_bucket{endpoint=\"/search\"}[5m])) by (le))",
          "legendFormat": "P50",
          "datasource": "Prometheus"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(inference_request_duration_seconds_bucket{endpoint=\"/search\"}[5m])) by (le))",
          "legendFormat": "P95",
          "datasource": "Prometheus"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(inference_request_duration_seconds_bucket{endpoint=\"/search\"}[5m])) by (le))",
          "legendFormat": "P99",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 3,
      "title": "Embedding Latency — P50 / P95 / P99",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(inference_embedding_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P50",
          "datasource": "Prometheus"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(inference_embedding_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95",
          "datasource": "Prometheus"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(inference_embedding_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P99",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 4,
      "title": "RAG Pipeline Latency — P50 / P95 / P99",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(inference_rag_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P50",
          "datasource": "Prometheus"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(inference_rag_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95",
          "datasource": "Prometheus"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(inference_rag_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P99",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 5,
      "title": "Cache Hit Ratio",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 16, "w": 6, "h": 6 },
      "targets": [
        {
          "expr": "sum(rate(inference_cache_hits_total[5m])) / (sum(rate(inference_cache_hits_total[5m])) + sum(rate(inference_cache_misses_total[5m])))",
          "legendFormat": "Hit Ratio",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": {
            "steps": [
              { "value": 0,   "color": "red" },
              { "value": 0.5, "color": "yellow" },
              { "value": 0.8, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Cache Hits by Level (L1 vs L2)",
      "type": "timeseries",
      "gridPos": { "x": 6, "y": 16, "w": 9, "h": 6 },
      "targets": [
        {
          "expr": "sum(rate(inference_cache_hits_total[1m])) by (level)",
          "legendFormat": "L{{level}} hits/s",
          "datasource": "Prometheus"
        },
        {
          "expr": "rate(inference_cache_misses_total[1m])",
          "legendFormat": "misses/s (model inference)",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "id": 7,
      "title": "Corpus Size (documents)",
      "type": "stat",
      "gridPos": { "x": 15, "y": 16, "w": 4, "h": 6 },
      "targets": [
        {
          "expr": "inference_corpus_size",
          "legendFormat": "Documents",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } }
      }
    },
    {
      "id": 8,
      "title": "System Status",
      "type": "stat",
      "gridPos": { "x": 19, "y": 16, "w": 5, "h": 6 },
      "targets": [
        {
          "expr": "inference_model_loaded",
          "legendFormat": "Model",
          "datasource": "Prometheus"
        },
        {
          "expr": "inference_redis_connected",
          "legendFormat": "Redis",
          "datasource": "Prometheus"
        },
        {
          "expr": "inference_ollama_ready",
          "legendFormat": "Ollama",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      }
    },
    {
      "id": 9,
      "title": "HTTP Errors Rate (4xx + 5xx)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "sum(rate(inference_requests_total{status_code=~\"4..|5..\"}[1m])) by (status_code, endpoint)",
          "legendFormat": "{{status_code}} {{endpoint}}",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "fixed", "fixedColor": "red" } }
      }
    },
    {
      "id": 10,
      "title": "Search Latency — P50 / P95 / P99",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 22, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(inference_search_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P50",
          "datasource": "Prometheus"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(inference_search_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95",
          "datasource": "Prometheus"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(inference_search_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P99",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    }
  ]
}
