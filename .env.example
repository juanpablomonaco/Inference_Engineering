# ---------------------------------------------------------------------------
# .env.example — Variables de entorno del proyecto
# ---------------------------------------------------------------------------
#
# USO:
#   cp .env.example .env
#   # Editar .env con tus valores reales
#   docker compose --env-file .env up --build
#
# IMPORTANTE:
#   - NUNCA commitear el archivo .env real al repositorio
#   - El archivo .env ya está en .gitignore
#   - En producción, usar AWS Secrets Manager, Vault, o Railway/Fly secrets
#
# Para generar API keys seguras:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
#   o: openssl rand -hex 32
# ---------------------------------------------------------------------------


# ---------------------------------------------------------------------------
# Servicio de inferencia
# ---------------------------------------------------------------------------

# Nivel de log: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Número de workers Uvicorn (producción: 2*CPUs+1, ej: 4 para 2 CPUs)
# Con múltiples workers el cache L1 es por-proceso; L2 (Redis) los unifica
WORKERS=1


# ---------------------------------------------------------------------------
# API Authentication (Fase 5)
# ---------------------------------------------------------------------------

# Lista de API keys válidas separadas por coma
# Vacío = auth desactivada (desarrollo local)
# Producción: usar keys de al menos 32 caracteres aleatorios
API_KEYS=


# ---------------------------------------------------------------------------
# Rate Limiting (Fase 5)
# ---------------------------------------------------------------------------

# Máximo de requests por ventana de tiempo
RATE_LIMIT_REQUESTS=60

# Tamaño de la ventana en segundos (sliding window)
RATE_LIMIT_WINDOW_SECONDS=60


# ---------------------------------------------------------------------------
# Redis (Fase 4)
# ---------------------------------------------------------------------------

# URL de conexión a Redis
# Docker: redis://redis:6379
# Redis Cloud: redis://:<password>@<host>:<port>
REDIS_URL=redis://redis:6379

# TTL de embeddings cacheados en Redis (segundos)
# 86400 = 24 horas
REDIS_EMBEDDING_TTL=86400


# ---------------------------------------------------------------------------
# LLM Backend (Fase 3 + Fase 6)
# ---------------------------------------------------------------------------

# Backend de generación: "ollama" (dev) o "vllm" (producción con GPU)
INFERENCE_BACKEND=ollama

# URL de Ollama (cuando INFERENCE_BACKEND=ollama)
OLLAMA_BASE_URL=http://ollama:11434

# URL de vLLM (cuando INFERENCE_BACKEND=vllm)
# Correr vLLM: docker run --gpus all -p 8001:8000 vllm/vllm-openai:latest \
#              --model meta-llama/Llama-3.1-8B-Instruct
VLLM_BASE_URL=http://vllm:8001

# Modelo LLM a usar (válido para ambos backends)
OLLAMA_MODEL=llama3.2:1b

# Número de documentos de contexto para RAG
RAG_TOP_K=3


# ---------------------------------------------------------------------------
# Grafana (Fase 6)
# ---------------------------------------------------------------------------

GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
# Producción: cambiar a una contraseña segura
# GRAFANA_PASSWORD=<password-seguro-aqui>


# ---------------------------------------------------------------------------
# HuggingFace
# ---------------------------------------------------------------------------

# Directorio de cache del modelo de embeddings dentro del contenedor
HF_HOME=/app/.cache/huggingface

# Si el modelo está en un repo privado de HuggingFace:
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
